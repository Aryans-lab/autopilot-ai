# ===========================================
# AUTO-PILOT AI - Configuration Template
# ===========================================
# Copy this file to .env and fill in your values
# All settings can be overridden via environment variables

# ===========================================
# AI PROVIDER CONFIGURATION
# ===========================================

# Primary AI Provider: auto, claude, openai, ollama
AI_PROVIDER=auto

# Model selection (provider-specific)
# Claude: opus, sonnet, haiku
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Ollama: llama3, mistral, codellama
AI_MODEL=sonnet

# API Keys (optional - uses free CLI tools by default)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Free Mode: Use CLI-based AI (no API key needed)
# Set to true for Claude ACP, Codex, or Ollama
FREE_MODE=true

# ===========================================
# MCP (Model Context Protocol)
# ===========================================

# MCP Server Configuration
MCP_ENABLED=false
MCP_SERVERS=

# Example MCP servers (comma-separated)
# mcp_github=https://github.com/modelcontextprotocol/server-github
# mcp_filesystem=builtin

# ===========================================
# MEMORY & EMBEDDINGS
# ===========================================

# Vector Database
EMBEDDING_PROVIDER=sentence-transformers  # sentence-transformers, openai
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB (vector store)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=.chromadb

# Memory settings
MEMORY_MAX_ENTRIES=10000
MEMORY_SIMILARITY_THRESHOLD=0.3

# ===========================================
# INTEGRATIONS
# ===========================================

# GitHub
GITHUB_TOKEN=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=autopilot@nanocorp.ai

# Twitter/X
TWITTER_BEARER_TOKEN=

# Discord
DISCORD_WEBHOOK_URL=

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#general

# Vercel
VERCEL_TOKEN=

# Netlify
NETLIFY_TOKEN=

# ===========================================
# SKILLS
# ===========================================

# Tavily (web research)
TAVILY_API_KEY=

# Linear (project management)
LINEAR_API_KEY=

# Notion
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ===========================================
# EXECUTION
# ===========================================

# Code sandbox settings
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY_LIMIT=512mb
SANDBOX_CPU_LIMIT=1

# Worker pool
MAX_WORKERS=10
WORKER_TIMEOUT=300

# Task settings
TASK_RETRY_COUNT=3
TASK_RETRY_DELAY=5

# ===========================================
# API SERVER
# ===========================================

# REST API
API_ENABLED=false
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=

# WebSocket
WS_ENABLED=false
WS_HOST=0.0.0.0
WS_PORT=8001

# CORS
API_CORS_ORIGINS=*

# Rate limiting
API_RATE_LIMIT=100/minute

# ===========================================
# LOGGING & OBSERVABILITY
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text

# Log file
LOG_FILE=autopilot.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
TRACING_ENDPOINT=http://localhost:4318

# Metrics (Datadog)
METRICS_ENABLED=false

# ===========================================
# STORAGE
# ===========================================

# Workspace directory
WORKSPACE_DIR=./workspace

# Data directory
DATA_DIR=./data

# Cache directory
CACHE_DIR=./.cache

# ===========================================
# PROFILES
# ===========================================

# Environment: development, testing, production
ENVIRONMENT=development

# Profile flags
PROFILE_MEMORY=true
PROFILE_MCP=true
PROFILE_SKILLS=true
PROFILE_API=false

# ===========================================
# DEVELOPMENT
# ===========================================

# Debug mode
DEBUG=false

# Reload on changes (development)
RELOAD=false

# Verbose output
VERBOSE=false

# ===========================================
# PROFILES
# ===========================================

# Development profile
[development]
DEBUG=true
VERBOSE=true
LOG_LEVEL=DEBUG
PROFILE_API=true

# Production profile
[production]
DEBUG=false
VERBOSE=false
LOG_LEVEL=INFO
PROFILE_API=true
